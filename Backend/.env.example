# Copy this file to .env and fill in real values.
# Do not commit .env — it's in .gitignore.

# Server
PORT=5000
NODE_ENV=development

# CORS — origin allowed to call the API (your frontend URL)
CLIENT_ORIGIN=http://localhost:3000

# URL the Safepay hosted form redirects back to after payment
PUBLIC_BASE_URL=http://localhost:3000

# MongoDB connection string (Atlas or local)
MONGO_URI=mongodb://127.0.0.1:27017/j-template

# Safepay — leave the keys blank to disable card payments and only offer COD.
# Get keys from Safepay Dashboard → Developers → API. Note the mapping:
#   SAFEPAY_API_KEY = the "API Key" (the sec_... value) — used as merchant_api_key
#   SAFEPAY_SECRET  = the long hex secret — used for SDK auth (authType: secret)
SAFEPAY_API_KEY=
SAFEPAY_SECRET=
SAFEPAY_ENV=sandbox
# Webhook signing secret (Dashboard → Developers → Webhooks). When set, webhooks
# failing HMAC verification are rejected; blank = lenient (tracker-guarded).
SAFEPAY_WEBHOOK_SECRET=
